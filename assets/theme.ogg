[
  {
    "category": "Menu",
    "icon": "Gamepad",
    "sub_category": [
      {
        "sub_name": "Basic",
        "description": "Basic cheats for growtopia.",
        "icon": "Handyman",
        "menu": [
          {
            "type": "labelapp",
            "icon": "DirectionsRun",
            "text": "Player Movement",
            "description": "Basic player movement menu."
          },
          {
            "text": "Antiban",
            "description": "Basic antiban, this will prevent basic anticheat from growtopia. Other antiban will always be applied automatically in other features.",
            "type": "toggle",
            "default": true
          },
          {
            "text": "Antibounce",
            "description": "Prevent death from deadly tiles.",
            "type": "toggle",
            "default": false,
            "expandable": true,
            "list_child": [
              {
                "text": "Antiban V2",
                "description": "Antiban for antibounce, this will keep you save from ban when parkour using antibounce.",
                "type": "toggle",
                "default": true
              },
              {
                "type":"tooltip",
                "icon": "note_icon",
                "text":"Effect",
                "support_text": "You can't punch people when Antiban V2 is on, people will see you like Falling"
              }
            ]
          },
          {
            "text": "Growz V2",
            "description": "Give more speed to your player",
            "type": "toggle",
            "default": false,
            "expandable": true,
            "list_child": [
              {
                "text": "Speed Growz",
                "type": "slider",
                "min": 0,
                "max": 8,
                "use_dot": true,
                "step":  7,
                "default": 3,
                "alias": "speed_growz"
              }
            ]
          },
          {
            "text": "Moonwalk",
            "type": "toggle",
            "default": false,
            "description": "Allows moving backward while facing forward.",
            "alias": "cheat_config_moonwalk"
          },
          {
            "text": "No Walk",
            "type": "toggle",
            "default": false,
            "description": "Disable move animation, this is not visual",
            "alias": "cheat_config_nowalk"
          },
          {
            "text": "Fast Fall",
            "type": "toggle",
            "default": false,
            "description": "Fall more faster",
            "alias": "cheat_config_fastfall",
            "expandable": true,
            "list_child": [
              {
                "text": "Speed Fall",
                "type": "slider",
                "min": 0,
                "max": 15,
                "default": 5,
                "alias": "cheat_config_fastfall_speed"
              }
            ]
          },
          {
            "text": "Slow Fall",
            "type": "toggle",
            "default": false,
            "description": "Fall more slower",
            "alias": "cheat_config_slowfall"
          },
          {
            "type": "labelapp",
            "icon": "ThumbUpOffAlt",
            "text": "Ability",
            "description": "Extends player ability."
          },
          {
            "text": "ModFly",
            "description": "Fly like creative mode",
            "type": "toggle",
            "default": false
          },
          {
            "text": "Anti Lava",
            "description": "Prevents death from lava, but does not prevent contact with lava.",
            "type": "toggle",
            "default": false
          },
          {
            "text": "Anti Respawn",
            "type": "toggle",
            "default": false,
            "description": "Respawn in current pos, but this can be dangerous",
            "alias": "cheat_config_antirespawn"
          },
          {
            "text": "See Locked Door",
            "description": "See label of locked door",
            "type": "toggle",
            "default": false
          },
          {
            "text": "NoClip and Ghost",
            "description": "Noclip allows you move throught blocks, visual and other player cant see",
            "alias": "noclip_and_ghost",
            "type": "toggle",
            "default": false,
            "expandable": true,
            "list_child": [
              {
                "text": "Developer Mode",
                "type": "toggle",
                "description": "Allows you place and break without owner permission, also this is visual",
                "alias": "developer_mode",
                "default": false,
                "autosave": true
              },
              {
                "text": "Touch Mode",
                "type": "toggle",
                "description": "Allows you to activate a block without owner permission, also this is visual",
                "alias": "activer_mode",
                "default": false,
                "autosave": true
              },
              {
                "text": "Don't disable Ghost",
                "type": "tooltip",
                "support_text": "Noclip in real Growtopia need ghost to avoid Autoban..."
              }
            ]
          },
          {
            "text": "Visual Invis V2",
            "description": "Visual invisible",
            "type": "toggle",
            "default": false,
            "alias": "features_invis_v2"
          },
          {
            "text": "Night Vision",
            "description": "Leveling up your eyes and dark spot now is being light spot",
            "type": "toggle",
            "default": false
          },
          {
            "text": "Can See Ghost",
            "description": "Enhances vision, turning dark areas into light",
            "type": "toggle",
            "default": false
          },
          {
            "type": "toggle",
            "text": "See Inside Chest",
            "description": "Allows you to see items inside closed chest",
            "default": false,
            "alias": "cheat_basic_seeinside_chest"
          },
          {
            "text": "See Fruit",
            "type": "toggle",
            "description": "Reveals fruits on tree",
            "default": false
          },
          {
            "text":"Fast Take",
            "type":"toggle",
            "description": "Instantly picks up items without delay",
            "default": false
          },
          {
            "text": "No Name",
            "type": "toggle",
            "default": false,
            "description": "Hide all name in world",
            "alias": "cheat_config_noname"
          },
          {
            "text": "Anti State",
            "type": "toggle",
            "default": false,
            "description": "Prevents state changes applied by the game.",
            "alias": "cheat_anti_state"
          },
          {
            "text": "Skip update items",
            "type": "toggle",
            "default": false,
            "description": "Skips item update processing to reduce sync overhead.",
            "alias": "cheat_skip_update_item"
          }
        ]
      },
      {
        "sub_name": "Visual",
        "description": "A cheat that only you can see",
        "icon": "RemoveRedEye",
        "menu": [
          {
            "type": "labelapp",
            "icon": "AllInbox",
            "text": "Inventory",
            "description": "Add item to inventory."
          },
          {
            "type":"item_picker",
            "text":"Item to add",
            "item": "Blank",
            "default": "Blank",
            "alias": "visual_inventory_itemid"
          },
          {
            "type": "dialog",
            "text": "Settings",
            "support_text": "Click to open settings",
            "menu": [
              {
                "type": "labelapp",
                "text": "Settings",
                "icon": "AllInbox"
              },
              {
                "type": "input_int",
                "text": "Amount to add",
                "default": "1",
                "label": "Amount to add into inventory",
                "placeholder": "200",
                "icon": "SettingsInputComponent",
                "alias": "visual_inventory_amount"
              }
            ]
          },
          {
            "type": "button",
            "text": "Add to inventory",
            "alias": "visual_inventory_add"
          },
          {
            "type": "tooltip",
            "text": "/finditem <name>",
            "support_text": "To find item in growtopia, and you can use it if you want.",
            "icon": "Bolt"
          },
          {
            "type": "tooltip",
            "text": "/setname <name>",
            "support_text": "To rename your growid visually.",
            "icon": "Bolt"
          },
          {
            "type": "tooltip",
            "text": "/setpunch <id>",
            "support_text": "To set your punch id visually.",
            "icon": "Bolt"
          },
          {
            "type": "labelapp",
            "icon": "Interests",
            "text": "Clothes",
            "description": "Use clothes visually and free. use /finditem <clothes> and click the target clothes to wear."
          },
          {
            "type": "toggle",
            "alias": "clothes_config_active",
            "text": "Keep visual clothes",
            "default": false
          },
          {
            "type": "dialog",
            "text": "Visual name",
            "support_text": "Click to setname",
            "menu": [
              {
                "type": "labelapp",
                "text": "Enter your name",
                "description": "Name is only visual and only visible on you.",
                "icon": "AccountCircle"
              },
              {
                "type": "input_string",
                "text": "Name",
                "default": "``Growtopian of Legend``",
                "alias": "config_name_visual",
                "label": "Name",
                "placeholder": "Growtopian",
                "icon": "PersonPinCircle"
              },
              {
                "type": "button",
                "text": "Set name",
                "alias": "config_refresh_name"
              }
            ]
          },
          {
            "type": "toggle",
            "alias": "name_config_active",
            "text": "Keep visual name",
            "default": false
          },
          {
            "type": "toggle",
            "alias": "punch_config_active",
            "text": "Keep visual punch",
            "default": false
          },
          {
            "type": "simple_display",
            "icon": "Checkroom",
            "text": "List clothes",
            "description": "A list visual clothes. Click to unequip",
            "alias": "visual_clothes_list",
            "default": "[]"
          }
        ]
      },
      {
        "sub_name": "FindPath",
        "icon": "Route",
        "description": "Teleport to target block",
        "menu": [
          {
            "type": "labelapp",
            "text": "FindPath",
            "icon": "Polyline",
            "description": "Teleport to target block, use wrench and click target. You will be automatically teleported."
          },
          {
            "text": "FindPath",
            "description": "Teleport to target block, use the findpath item and click target tile. You will be automatically teleported.",
            "type": "toggle",
            "default": false,
            "expandable": true,
            "always_expand": true,
            "list_child": [
              {
                "type":"item_picker",
                "text":"FindPath",
                "item": "Wrench",
                "default": "Wrench",
                "alias": "findpath_config_item"
              },
              {
                "type": "slider",
                "text": "Block jump",
                "min": 1,
                "max": 8,
                "default": 8,
                "alias": "findpath_config_blockjump"
              },
              {
                "type": "toggle",
                "text": "Debug paths",
                "default": false,
                "alias": "findpath_config_debug_paths"
              },
              {
                "type": "toggle",
                "text": "Debug current location",
                "default": false,
                "alias": "findpath_config_current_loc"
              },
              {
                "type": "toggle",
                "text": "Overclock",
                "description": "Make the teleport is more faster, but use it correctly.",
                "alias": "findpath_config_overclock",
                "default": true
              },
              {
                "type":"tooltip",
                "icon": "tips_icon",
                "text":"Tips",
                "support_text": "Don't spam if the blocks is about 500 blocks teleport"
              }
            ]
          }
        ]
      },
      {
        "sub_name": "Fast",
        "icon": "FastForward",
        "description": "Faster abilty for action",
        "menu": [
          {
            "type": "labelapp",
            "text": "Actions",
            "description": "Faster action for time saving",
            "icon": "Build"
          },
          {
            "type": "toggle",
            "text": "Fast Drop",
            "description": "Automatically drop item when you trying to drop it.",
            "alias": "cheat_config_fastdrop_active",
            "default": false
          },
          {
            "type": "dialog",
            "text": "Fast drop settings",
            "support_text": "Click to open fast drop settings.",
            "menu": [
              {
                "type": "labelapp",
                "text": "Fast drop settings",
                "description": "Settings for fast drop",
                "icon": "Build"
              },
              {
                "type": "toggle",
                "text": "Custom count",
                "alias": "cheat_config_fastdrop_custom"
              },
              {
                "type": "input_int",
                "text": "Count to drop",
                "default": "200",
                "label": "Count",
                "placeholder": "Count",
                "icon": "Edit",
                "alias": "cheat_config_fastdrop_count"
              }
            ]
          },
          {
            "type": "toggle",
            "text": "Fast Trash",
            "description": "Automatically trash item when you trying to trash it.",
            "alias": "cheat_config_fasttrash_active",
            "default": false
          },
          {
            "type": "dialog",
            "text": "Fast trash settings",
            "support_text": "Click to open fast trash settings.",
            "menu": [
              {
                "type": "labelapp",
                "text": "Fast trash settings",
                "description": "Settings for fast trash",
                "icon": "Delete"
              },
              {
                "type": "toggle",
                "text": "Custom count",
                "alias": "cheat_config_fasttrash_custom"
              },
              {
                "type": "input_int",
                "text": "Count to drop",
                "default": "200",
                "label": "Count",
                "placeholder": "Count",
                "icon": "Edit",
                "alias": "cheat_config_fasttrash_count"
              }
            ]
          },
          {
            "type": "label",
            "text": "Vending"
          },
          {
            "type": "toggle",
            "text": "Fast Buy",
            "description": "Automatically buy item in vend when you wrench it",
            "alias": "cheat_config_fastbuy_active",
            "default": false
          },
          {
            "type": "dialog",
            "text": "Fast buy settings",
            "support_text": "Click to open fast buy settings.",
            "menu": [
              {
                "type": "labelapp",
                "text": "Fast buy settings",
                "description": "Settings for fast buy",
                "icon": "AttachMoney"
              },
              {
                "type": "toggle",
                "text": "Custom count",
                "alias": "cheat_config_fastbuy_custom"
              },
              {
                "type": "input_int",
                "text": "Amount to buy",
                "default": "200",
                "label": "Count",
                "placeholder": "Amount",
                "icon": "Edit",
                "alias": "cheat_config_fastbuy_amount"
              }
            ]
          }
        ]
      },
      {
        "description": "Extra Sensory Perception",
        "icon": "AutoAwesome",
        "menu": [
          {
            "type": "labelapp",
            "icon": "AutoAwesome",
            "text": "ESP",
            "description": "Draw a line or bounding box around entities"
          },
          {
            "type": "toggle",
            "text": "Player",
            "default": false,
            "alias": "cheat_esp_player",
            "description": "Draw line and box between your player to others."
          },
          {
            "alias": "cheat_esp_item",
            "default": false,
            "description": "Draw line and box between your player to items.",
            "text": "Item",
            "type": "toggle"
          },
          {
            "type": "toggle",
            "text": "Ghost",
            "default": false,
            "expandable": true,
            "alias": "cheat_esp_ghost",
            "description": "Draw line and box between your player to ghosts.",
            "list_child": [
              {
                "type": "toggle",
                "text": "Force draw all types",
                "default": false,
                "alias": "cheat_esp_ghost_force",
                "description": "Force draw all ghost types"
              }
            ]
          }
        ],
        "sub_name": "ESP"
      },
      {
        "sub_name": "Extract",
        "description": "Extract some floating items in tile.",
        "icon": "SwipeDown",
        "menu": [
          {
            "type": "labelapp",
            "text": "Dynamo Extractor",
            "description": "Extract some floating items in tile.",
            "icon": "SwipeDown"
          },
          {
            "type": "toggle_button",
            "text": "Enable Dynamo Extrator",
            "alias": "dynamo_start"
          },
          {
            "type": "tooltip",
            "icon": "tips_icon",
            "text": "How to use ?",
            "support_text": "After enable the feature, you must trigger it by wrenching dropped items."
          }
        ]
      },
      {
        "sub_name": "Info",
        "icon": "RawOn",
        "description": "Display raw information",
        "menu": [
          {
            "type": "simple_display",
            "icon": "Commit",
            "text": "List raw information local player",
            "description": "A list raw information about current local player.",
            "alias": "display_list_netavatar_coordinate",
            "default": "[]"
          },
          {
            "type": "button",
            "text": "Refresh",
            "alias": "rawinfo_netavatarlocal"
          }
        ]
      },
      {
        "sub_name": "Debug",
        "icon": "BugReport",
        "description": "Debug the game, this is usefull when you creating lua scripts.",
        "menu": [
          {
            "type": "labelapp",
            "text": "Tile debugger",
            "icon": "Apps",
            "description": "Show information about last punched tile."
          },
          {
            "type": "toggle",
            "text": "Enable",
            "description": "Punch tile to debug.",
            "alias": "debug_tile"
          },
          {
            "type": "body",
            "alias": "debug_tile_log",
            "text": "-"
          },
          {
            "type": "labelapp",
            "text": "Packet Debugger",
            "icon": "BugReport",
            "description": "Capture and filter packets by type and string. Max 200 entries per category."
          },
          {
            "text": "Text Packet",
            "type": "toggle",
            "description": "Capture outgoing text packets (action|input, etc).",
            "alias": "debug_text_packet",
            "default": false,
            "expandable": true,
            "list_child": [
              {
                "type": "dialog",
                "text": "Filter Settings",
                "support_text": "Click to set type and string filters",
                "menu": [
                  {
                    "type": "labelapp",
                    "text": "Text Packet Filter",
                    "description": "Set filters for text packet capture",
                    "icon": "FilterList"
                  },
                  {
                    "type": "input_int",
                    "text": "Filter by type",
                    "default": "-1",
                    "label": "Packet type (-1 = all)",
                    "placeholder": "-1",
                    "icon": "FilterList",
                    "alias": "debug_sendpacket_type_filter"
                  },
                  {
                    "type": "input_string",
                    "text": "Filter by string",
                    "default": "",
                    "label": "String to search in packet",
                    "placeholder": "action|input",
                    "icon": "Search",
                    "alias": "debug_sendpacket_str_filter"
                  }
                ]
              },
              {
                "type": "dialog",
                "text": "View Logs",
                "support_text": "Click to view captured text packets",
                "menu": [
                  {
                    "type": "labelapp",
                    "text": "Text Packet Logs",
                    "description": "Captured text packets (filtered). Click item to copy.",
                    "icon": "Commit"
                  },
                  {
                    "type": "button",
                    "text": "Clear logs",
                    "alias": "debug_sendpacket_clear"
                  },
                  {
                    "type": "input_string",
                    "text": "Selected log",
                    "default": "",
                    "label": "Full packet text",
                    "placeholder": "Click a log entry above to view here",
                    "icon": "ContentPaste",
                    "alias": "debug_sendpacket_selected",
                    "multiline": true,
                    "line_count": 8
                  },
                  {
                    "type": "simple_display",
                    "icon": "Commit",
                    "text": "Logs",
                    "description": "Click item to view full text.",
                    "alias": "debug_sendpacket_list",
                    "default": "[]"
                  },
                  {
                    "type": "button",
                    "text": "Copy to clipboard",
                    "alias": "debug_sendpacket_copy"
                  }
                ]
              }
            ]
          },
          {
            "text": "Raw Packet",
            "type": "toggle",
            "description": "Capture outgoing raw tank packets (TankPacketStruct).",
            "alias": "debug_raw_packet",
            "default": false,
            "expandable": true,
            "list_child": [
              {
                "type": "dialog",
                "text": "Filter Settings",
                "support_text": "Click to set type and string filters",
                "menu": [
                  {
                    "type": "labelapp",
                    "text": "Raw Packet Filter",
                    "description": "Set filters for raw packet capture",
                    "icon": "FilterList"
                  },
                  {
                    "type": "input_int",
                    "text": "Filter by type",
                    "default": "-1",
                    "label": "Packet type (-1 = all)",
                    "placeholder": "-1",
                    "icon": "FilterList",
                    "alias": "debug_rawpacket_type_filter"
                  },
                  {
                    "type": "input_string",
                    "text": "Filter by string",
                    "default": "",
                    "label": "String to search in packet",
                    "placeholder": "packetType",
                    "icon": "Search",
                    "alias": "debug_rawpacket_str_filter"
                  }
                ]
              },
              {
                "type": "dialog",
                "text": "View Logs",
                "support_text": "Click to view captured raw packets",
                "menu": [
                  {
                    "type": "labelapp",
                    "text": "Raw Packet Logs",
                    "description": "Captured raw packets (filtered). Click item to copy.",
                    "icon": "Commit"
                  },
                  {
                    "type": "button",
                    "text": "Clear logs",
                    "alias": "debug_rawpacket_clear"
                  },
                  {
                    "type": "input_string",
                    "text": "Selected log",
                    "default": "",
                    "label": "Full packet text",
                    "placeholder": "Click a log entry above to view here",
                    "icon": "ContentPaste",
                    "alias": "debug_rawpacket_selected",
                    "multiline": true,
                    "line_count": 8
                  },
                  {
                    "type": "simple_display",
                    "icon": "Commit",
                    "text": "Logs",
                    "description": "Click item to view full text.",
                    "alias": "debug_rawpacket_list",
                    "default": "[]"
                  },
                  {
                    "type": "button",
                    "text": "Copy to clipboard",
                    "alias": "debug_rawpacket_copy"
                  }
                ]
              }
            ]
          },
          {
            "text": "OnVariant",
            "type": "toggle",
            "description": "Capture incoming variant function calls from server.",
            "alias": "debug_on_variant",
            "default": false,
            "expandable": true,
            "list_child": [
              {
                "type": "dialog",
                "text": "Filter Settings",
                "support_text": "Click to set variant name and string filters",
                "menu": [
                  {
                    "type": "labelapp",
                    "text": "OnVariant Filter",
                    "description": "Set filters for variant capture",
                    "icon": "FilterList"
                  },
                  {
                    "type": "input_string",
                    "text": "Filter by variant name",
                    "default": "",
                    "label": "Variant function name (e.g OnConsoleMessage)",
                    "placeholder": "OnConsoleMessage",
                    "icon": "FilterList",
                    "alias": "debug_variant_name_filter"
                  },
                  {
                    "type": "input_string",
                    "text": "Filter by string",
                    "default": "",
                    "label": "String to search in variant data",
                    "placeholder": "",
                    "icon": "Search",
                    "alias": "debug_variant_str_filter"
                  }
                ]
              },
              {
                "type": "dialog",
                "text": "View Logs",
                "support_text": "Click to view captured variant calls",
                "menu": [
                  {
                    "type": "labelapp",
                    "text": "OnVariant Logs",
                    "description": "Captured variant calls (filtered). Click item to copy.",
                    "icon": "Commit"
                  },
                  {
                    "type": "button",
                    "text": "Clear logs",
                    "alias": "debug_variant_clear"
                  },
                  {
                    "type": "input_string",
                    "text": "Selected log",
                    "default": "",
                    "label": "Full variant text",
                    "placeholder": "Click a log entry above to view here",
                    "icon": "ContentPaste",
                    "alias": "debug_variant_selected",
                    "multiline": true,
                    "line_count": 8
                  },
                  {
                    "type": "simple_display",
                    "icon": "Commit",
                    "text": "Logs",
                    "description": "Click item to view full text.",
                    "alias": "debug_variant_list",
                    "default": "[]"
                  },
                  {
                    "type": "button",
                    "text": "Copy to clipboard",
                    "alias": "debug_variant_copy"
                  }
                ]
              }
            ]
          },
          {
            "text": "GameTankUpdate",
            "type": "toggle",
            "description": "Capture incoming game tank update packets.",
            "alias": "debug_tankupdate",
            "default": false,
            "expandable": true,
            "list_child": [
              {
                "type": "dialog",
                "text": "Filter Settings",
                "support_text": "Click to set type and string filters",
                "menu": [
                  {
                    "type": "labelapp",
                    "text": "GameTankUpdate Filter",
                    "description": "Set filters for tank update capture",
                    "icon": "FilterList"
